# ── Variables de entorno — COPIA ESTE ARCHIVO A .env.local Y RELLENA LOS VALORES ──
#
# REGLAS DE SEGURIDAD:
# · NEXT_PUBLIC_* → se exponen al navegador (cliente). Solo usar para datos públicos.
# · Sin prefijo NEXT_PUBLIC_ → solo disponibles en el servidor (API Routes / Edge).
#
# En Vercel: agrega estas variables en Settings → Environment Variables
# NUNCA subas .env.local a git (ya está en .gitignore ✅)

# ─── CLIENTE (público — se envía al navegador) ───────────────────────────────
# URL del nodo RPC de Solana. Usa un proveedor dedicado en producción (Helius, QuickNode, etc.)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Red de Solana: "devnet" | "mainnet-beta" | "testnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ─── SERVIDOR (privado — NO se exponen al cliente) ───────────────────────────
# Clave de API de OpenAI (solo para uso en API Routes del servidor)
OPENAI_API_KEY=sk-...tu-key-aqui...

# Clave privada de la wallet del agente (array de bytes en formato JSON)
# ⚠️  JAMÁS uses NEXT_PUBLIC_ en esta variable
AGENT_WALLET_PRIVATE_KEY=[1,2,3,...]
